  function findMaxChar(str) {
    const charMap = {};
    let maxCount = 0;
    let maxChar = '';

    // 1. Frequency Map banayein
    for (let char of str) {
      charMap[char] = (charMap[char] || 0) + 1;

      // 2. Saath-saath check karein ki kya ye ab tak ka max hai?
      if (charMap[char] > maxCount) {
        maxCount = charMap[char];
        maxChar = char;
      }
    }

    console.log(charMap);
    // 3. Output format: [{letter: 'a', count: 3}]
    return [{ letter: maxChar, count: maxCount }];
  }

  const input = 'anagrams';
  console.log(findMaxChar(input));
  // Output: [{ letter: 'a', count: 3 }]
